# Gitignore settings for ESPHome
# This is an example and may include too much for your use-case.
# You can modify this file to suit your needs.
/.esphome/
/secrets.yaml
/custom-esphome-trane.yaml
/custom-secrets.yaml
/trane-capture-*.log

# Python bytecode cache (ESPHome codegen artifacts)
__pycache__/
*.pyc
